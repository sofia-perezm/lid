<!doctype html>
<html lang="{{ metadata.language }}">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>{{ title or metadata.title }}</title>
		<meta name="description" content="{{ description or metadata.description }}">
		<link rel="alternate" href="/feed/feed.xml" type="application/atom+xml" title="{{ metadata.title }}">

		<style>{% include "public/css/index.css" %}</style>
		<style>{% getBundle "css" %}</style>

		<script type="module">{% include "node_modules/@zachleat/heading-anchors/heading-anchors.js" %}</script>
	</head>
	<body>
		<div id="cursor"></div>
		<a href="#main" id="skip-link" class="visually-hidden">Ir al contenido principal</a>

		<header class="cell header">
			<button id="nav-toggle" aria-label="Colapsar navegación" aria-expanded="true">☰</button>
			<a href="/" class="brand">{{ metadata.title }}</a>
		</header>

		<aside class="cell sidebar" id="sidebar">
			<nav aria-label="Menú principal">
				<div class="dir-header">Navegación</div>
				<ul class="nav-list">
				{%- for entry in collections.all | eleventyNavigation %}
					<li><a href="{{ entry.url }}"{% if entry.url == page.url %} aria-current="page"{% endif %}>{{ entry.title }}</a></li>
				{%- endfor %}
				</ul>
			</nav>
		</aside>

		<main class="cell main-content" id="main">
			<heading-anchors>
				{{ content | safe }}
			</heading-anchors>
		</main>

		<footer class="cell footer">
			<span class="scrolling-text">Laboratorio de Interacción Digital &nbsp;—&nbsp; LID UDP &nbsp;—&nbsp; Universidad Diego Portales &nbsp;—&nbsp; Facultad de Arquitectura, Arte y Diseño &nbsp;—&nbsp; Santiago, Chile &nbsp;—&nbsp; {{ metadata.title }} &nbsp;—&nbsp; Diseño de Interacción &nbsp;—&nbsp; Interfaces Humano-Computador &nbsp;—&nbsp; Diseño de Máquinas Electrónicas</span>
		</footer>

		<script>
			// Cursor personalizado
			const cursor = document.getElementById('cursor');
			document.addEventListener('mousemove', e => {
				cursor.style.left = e.clientX + 'px';
				cursor.style.top  = e.clientY + 'px';
			});

			// Toggle sidebar
			const toggle = document.getElementById('nav-toggle');
			toggle.addEventListener('click', () => {
				const collapsed = document.body.classList.toggle('nav-collapsed');
				toggle.setAttribute('aria-expanded', String(!collapsed));
			});
		</script>

		<script type="module" src="{% getBundleFileUrl "js" %}"></script>
	</body>
</html>
